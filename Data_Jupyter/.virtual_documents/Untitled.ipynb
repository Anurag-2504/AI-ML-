import numpy as np
import time


#execution performance

size = 1_000_000

#python list
py_list = list(range(size))
start = time.time()
sq_list = [x**2 for x in py_list]
end = time.time()
print(f"Python list time = {end-start} sec")

#numpy arrays
np_arr=np.array(py_list)
start=time.time()
sq_array=np_arr**2
end = time.time()
print(f"Numpy array list time = {end-start} sec")



